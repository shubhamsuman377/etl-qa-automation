--Main Stored Procedure
CREATE OR REPLACE PROCEDURE IT_COMPANY.EMPLOYEES.RUN_DQ_CHECKS()
RETURNS STRING
LANGUAGE JAVASCRIPT
EXECUTE AS CALLER
AS
$$
try {

snowflake.createStatement({
sqlText:`TRUNCATE TABLE IT_COMPANY.EMPLOYEES.DQ_RESULTS`
}).execute();

var rs = snowflake.createStatement({
sqlText:`SELECT SRC_TABLE, TGT_TABLE, KEYS
FROM IT_COMPANY.EMPLOYEES.DQ_TABLE_CONFIG`
}).execute();

var tables = [];

while(rs.next()){
tables.push({
src_table: rs.getColumnValue(1),
tgt_table: rs.getColumnValue(2),
keys: JSON.parse(rs.getColumnValue(3))
});
}

for(var i=0;i<tables.length;i++){

var t = tables[i];

var srcTable = t.src_table;
var tgtTable = t.tgt_table;
var keys = t.keys;

var keyExpr = keys.join(', ');

var tableName = tgtTable.split('.')[2];
var schemaName = tgtTable.split('.')[1];


// COUNT CHECK

var sql_count = `
SELECT
(SELECT COUNT(*) FROM ${srcTable}) SRC_COUNT,
(SELECT COUNT(*) FROM ${tgtTable}) TGT_COUNT
`;

var rs_count = snowflake.createStatement({sqlText:sql_count}).execute();
rs_count.next();

var src_count = rs_count.getColumnValue(1);
var tgt_count = rs_count.getColumnValue(2);

var status = (src_count == tgt_count) ? 'PASS' : 'FAIL';

snowflake.createStatement({
sqlText:`INSERT INTO IT_COMPANY.EMPLOYEES.DQ_RESULTS
(TABLE_NAME,SCHEMA_NAME,CHECK_TYPE,STATUS,DETAILS,RUN_TIMESTAMP)
VALUES(?,?,'COUNT_CHECK',?, ?,CURRENT_TIMESTAMP)`,
binds:[tableName,schemaName,status,`SRC=${src_count},TGT=${tgt_count}`]
}).execute();


// DUPLICATE CHECK

var sql_dup_src = `
SELECT COUNT(*) FROM (
SELECT ${keyExpr},COUNT(*)
FROM ${srcTable}
GROUP BY ${keyExpr}
HAVING COUNT(*)>1
)
`;

var sql_dup_tgt = `
SELECT COUNT(*) FROM (
SELECT ${keyExpr},COUNT(*)
FROM ${tgtTable}
GROUP BY ${keyExpr}
HAVING COUNT(*)>1
)
`;

var rs_dup_src = snowflake.createStatement({sqlText:sql_dup_src}).execute(); rs_dup_src.next();
var rs_dup_tgt = snowflake.createStatement({sqlText:sql_dup_tgt}).execute(); rs_dup_tgt.next();

var d1 = rs_dup_src.getColumnValue(1);
var d2 = rs_dup_tgt.getColumnValue(1);

var status = (d1==0 && d2==0) ? 'PASS':'FAIL';

snowflake.createStatement({
sqlText:`INSERT INTO IT_COMPANY.EMPLOYEES.DQ_RESULTS
(TABLE_NAME,SCHEMA_NAME,CHECK_TYPE,STATUS,DETAILS,RUN_TIMESTAMP)
VALUES(?,?,'DUPLICATE_CHECK',?, ?,CURRENT_TIMESTAMP)`,
binds:[tableName,schemaName,status,`SRC_DUP=${d1},TGT_DUP=${d2}`]
}).execute();


// NULL CHECK

var null_conditions = keys.map(k=>`${k} IS NULL`).join(' OR ');

var sql_null_src = `SELECT COUNT(*) FROM ${srcTable} WHERE ${null_conditions}`;
var sql_null_tgt = `SELECT COUNT(*) FROM ${tgtTable} WHERE ${null_conditions}`;

var rs_null_src = snowflake.createStatement({sqlText:sql_null_src}).execute(); rs_null_src.next();
var rs_null_tgt = snowflake.createStatement({sqlText:sql_null_tgt}).execute(); rs_null_tgt.next();

var n1 = rs_null_src.getColumnValue(1);
var n2 = rs_null_tgt.getColumnValue(1);

var status = (n1==0 && n2==0) ? 'PASS':'FAIL';

snowflake.createStatement({
sqlText:`INSERT INTO IT_COMPANY.EMPLOYEES.DQ_RESULTS
(TABLE_NAME,SCHEMA_NAME,CHECK_TYPE,STATUS,DETAILS,RUN_TIMESTAMP)
VALUES(?,?,'NULL_CHECK',?, ?,CURRENT_TIMESTAMP)`,
binds:[tableName,schemaName,status,`SRC_NULL=${n1},TGT_NULL=${n2}`]
}).execute();


// STRUCTURE CHECK

var sql_cols_src = `
SELECT COLUMN_NAME
FROM INFORMATION_SCHEMA.COLUMNS
WHERE TABLE_SCHEMA='${srcTable.split('.')[1]}'
AND TABLE_NAME='${srcTable.split('.')[2]}'
`;

var sql_cols_tgt = `
SELECT COLUMN_NAME
FROM INFORMATION_SCHEMA.COLUMNS
WHERE TABLE_SCHEMA='${tgtTable.split('.')[1]}'
AND TABLE_NAME='${tgtTable.split('.')[2]}'
`;

var cols_src = snowflake.createStatement({sqlText:sql_cols_src}).execute();
var cols_tgt = snowflake.createStatement({sqlText:sql_cols_tgt}).execute();

var list_src=[];
var list_tgt=[];

while(cols_src.next()){list_src.push(cols_src.getColumnValue(1));}
while(cols_tgt.next()){list_tgt.push(cols_tgt.getColumnValue(1));}

var struct_ok = (list_src.sort().join()==list_tgt.sort().join());

var status = struct_ok ? 'PASS':'FAIL';

snowflake.createStatement({
sqlText:`INSERT INTO IT_COMPANY.EMPLOYEES.DQ_RESULTS
(TABLE_NAME,SCHEMA_NAME,CHECK_TYPE,STATUS,DETAILS,RUN_TIMESTAMP)
VALUES(?,?,'STRUCTURE_CHECK',?, ?,CURRENT_TIMESTAMP)`,
binds:[tableName,schemaName,status,`SRC_COLS=${list_src.length},TGT_COLS=${list_tgt.length}`]
}).execute();


// DATA COMPARISON

var sql_diff = `
SELECT COUNT(*) FROM (
(SELECT * FROM ${srcTable}
MINUS
SELECT * FROM ${tgtTable})
UNION
(SELECT * FROM ${tgtTable}
MINUS
SELECT * FROM ${srcTable})
)
`;

var rs_diff = snowflake.createStatement({sqlText:sql_diff}).execute();
rs_diff.next();

var diff_cnt = rs_diff.getColumnValue(1);

var status = (diff_cnt==0)?'PASS':'FAIL';

snowflake.createStatement({
sqlText:`INSERT INTO IT_COMPANY.EMPLOYEES.DQ_RESULTS
(TABLE_NAME,SCHEMA_NAME,CHECK_TYPE,STATUS,DETAILS,RUN_TIMESTAMP)
VALUES(?,?,'DATA_COMPARISON',?, ?,CURRENT_TIMESTAMP)`,
binds:[tableName,schemaName,status,`DIFF_COUNT=${diff_cnt}`]
}).execute();


// BUSINESS RULE CHECKS

var sql_rules = `
SELECT RULE_NAME,RULE_SQL
FROM IT_COMPANY.EMPLOYEES.DQ_BUSINESS_RULES
WHERE TABLE_NAME='${tableName}'
AND SCHEMA_NAME='${schemaName}'
AND IS_ACTIVE='Y'
`;

var rs_rules = snowflake.createStatement({sqlText:sql_rules}).execute();

while(rs_rules.next()){

var ruleName = rs_rules.getColumnValue(1);
var ruleSql = rs_rules.getColumnValue(2);

var rs_rule = snowflake.createStatement({sqlText:ruleSql}).execute();
rs_rule.next();

var bad_count = rs_rule.getColumnValue(1);

var status = (bad_count==0)?'PASS':'FAIL';

snowflake.createStatement({
sqlText:`INSERT INTO IT_COMPANY.EMPLOYEES.DQ_RESULTS
(TABLE_NAME,SCHEMA_NAME,CHECK_TYPE,STATUS,DETAILS,RUN_TIMESTAMP)
VALUES(?, ?, ?, ?, ?, CURRENT_TIMESTAMP)`,
binds:[
tableName,
schemaName,
'BUSINESS_RULE_'+ruleName,
status,
'FAILED_RECORDS='+bad_count
]
}).execute();

}

}

return 'DQ CHECKS COMPLETED';

}
catch(err){
return 'FAILED: '+err;
}
$$;



CALL IT_COMPANY.EMPLOYEES.RUN_DQ_CHECKS();

