    TABLE_NAME          STRING,
    CHECK_TYPE          STRING,
    STATUS              STRING,
    DETAILS             STRING,
    RUN_TIMESTAMP       TIMESTAMP
);

-- =============================================
-- CONFIG TABLE (enhanced with per-check toggles)
-- =============================================
CREATE OR REPLACE TABLE DB_NAME.SCHEMA_NAME.DQ_TABLE_CONFIG (
    SRC_TABLE               STRING,
    TGT_TABLE               STRING,
    KEYS                    STRING,
    EXCLUDED_COLUMNS_SRC    STRING,
    EXCLUDED_COLUMNS_TGT    STRING,
    -- Per-check toggle flags (Y = active, N = skip)
    IS_COUNT_CHECK          STRING  DEFAULT 'Y',
    IS_DUPLICATE_CHECK      STRING  DEFAULT 'Y',
    IS_NULL_CHECK           STRING  DEFAULT 'Y',
    IS_STRUCTURE_CHECK      STRING  DEFAULT 'Y',
    IS_DATA_COMPARISON      STRING  DEFAULT 'Y',
    IS_BUSINESS_RULE_CHECK  STRING  DEFAULT 'Y'
);

